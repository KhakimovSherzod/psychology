generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ------------------ ENUMS ------------------
//

enum Role {
  USER
  ADMIN
  OWNER
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum VideoStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CLICK
  PAYME
  STRIPE
  PAYPAL
  MANUAL
}

enum VideoProvider {
  BUNNY
  YOUTUBE
  MUX
  CLOUDFLARE
}

enum PlaylistStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OrderStatus {
  CREATED
  PENDING_PAYMENT
  PAID
  CANCELLED
  EXPIRED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  EXPIRED
}

//
// ------------------ USERS ------------------
//

model user {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(uuid())
  name          String
  role          Role      @default(USER)
  status        Status    @default(ACTIVE)
  phone         String    @unique
  pinHash       String
  profileImage  String?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?
  deletedAt     DateTime?

  payments      payment[]
  enrollments   enrollment[]
  videoProgress videoProgress[]
  wishlists     wishlist[]
  reviews       review[]
  devices       device[]
  orders        order[]
  carts         cart[]
}

//
// ------------------ DEVICE ------------------
//

model device {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())

  userId      Int
  user        user      @relation(fields: [userId], references: [id])

  deviceName  String?
  deviceType  String?
  os          String?
  browser     String?
  ipAddress   String?

  deviceToken String?
  lastUsedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([userId])
  @@index([lastUsedAt])
}

//
// ------------------ PLAYLIST ------------------
//

model playlist {
  id                   Int            @id @default(autoincrement())
  uuid                 String         @unique @default(uuid())
  title                String
  description          String
  playlistThumbnailUrl String
  price                Int
  visibility           Visibility     @default(PRIVATE)
  status               PlaylistStatus @default(DRAFT)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?
  publishedAt          DateTime?
  archivedAt           DateTime?

  videos       video[]
  categories   category[]     @relation("PlaylistCategories")
  enrollments  enrollment[]
  wishlists    wishlist[]
  reviews      review[]
  orderItems   orderItem[]
  cartItems    cartItem[]

  @@index([status])
  @@index([status, visibility])
  @@index([status, visibility, publishedAt])
}

//
// ------------------ VIDEO ------------------
//

model video {
  id                Int         @id @default(autoincrement())
  uuid              String      @unique @default(uuid())
  provider          VideoProvider
  externalVideoId   String
  title             String
  description       String?
  videoThumbnailUrl String
  order             Int
  isFree            Boolean     @default(false)
  status            VideoStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?
  publishedAt       DateTime?
  archivedAt        DateTime?

  playlistId        Int
  playlist          playlist    @relation(fields: [playlistId], references: [id])

  categories        category[]  @relation("VideoCategories")
  progress          videoProgress[]

  @@index([playlistId])
  @@index([status])
  @@unique([playlistId, order])
  @@index([playlistId, status, order])
}

//
// ------------------ CATEGORY ------------------
//

model category {
  id         Int         @id @default(autoincrement())
  uuid       String      @unique @default(uuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  videos     video[]     @relation("VideoCategories")
  playlists  playlist[]  @relation("PlaylistCategories")
}
//
// ------------------ CART -------------------
//

model cart {
  id        Int @id @default(autoincrement())
  uuid      String @unique @default(uuid())

  userId    Int
  user      user @relation(fields: [userId], references: [id])

  status    CartStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     cartItem[]

  @@unique([userId, status])
}

model cartItem {
  id         Int @id @default(autoincrement())
  uuid       String @unique @default(uuid())

  cartId     Int
  cart       cart @relation(fields: [cartId], references: [id])

  playlistId Int
  playlist   playlist @relation(fields: [playlistId], references: [id])

  price      Int

  createdAt  DateTime @default(now())

  @@unique([cartId, playlistId]) // prevents duplicates

}
//
// ------------------ ORDER ------------------
//

model order {
  id         Int         @id @default(autoincrement())
  uuid       String      @unique @default(uuid())

  userId     Int
  user       user        @relation(fields: [userId], references: [id])

  amount     Int
  currency   String      @default("UZS")
  status     OrderStatus @default(CREATED)
  expiresAt  DateTime
  paidAt     DateTime?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      orderItem[]
  payments   payment[]

  @@index([userId])
  @@index([status])
}

//
// ------------------ ORDER ITEM ------------------
//

model orderItem {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())

  orderId     Int
  order       order    @relation(fields: [orderId], references: [id])

  playlistId  Int
  playlist    playlist @relation(fields: [playlistId], references: [id])

  price       Int      
  currency    String   @default("UZS")

  createdAt   DateTime @default(now())

  enrollment  enrollment? // enrollment created after payment

  @@unique([orderId, playlistId]) // prevent duplicate items in same order
  @@index([orderId])
  @@index([playlistId])
}

//
// ------------------ PAYMENT ------------------
//

model payment {
  id            Int             @id @default(autoincrement())
  uuid          String          @unique @default(uuid())
  amount        Int
  currency      String          @default("UZS")
  paymentMethod PaymentMethod   @default(MANUAL)
  status        PaymentStatus   @default(PENDING)
  transactionId String?
  proofUrl      String?
  paidAt        DateTime?
  refundReason  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId        Int
  user          user            @relation(fields: [userId], references: [id])

  orderId       Int
  order         order           @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

//
// ------------------ ENROLLMENT ------------------
//

model enrollment {
  id          Int              @id @default(autoincrement())
  uuid        String           @unique @default(uuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  expiresAt   DateTime
  status      EnrollmentStatus @default(ACTIVE)

  userId      Int
  user        user             @relation(fields: [userId], references: [id])

  playlistId  Int
  playlist    playlist         @relation(fields: [playlistId], references: [id])

  orderItemId Int?             @unique
  orderItem   orderItem?       @relation(fields: [orderItemId], references: [id])

  @@index([userId])
  @@index([orderItemId])
  @@index([playlistId])
  @@index([status])
}

//
// ------------------ VIDEO PROGRESS ------------------
//

model videoProgress {
  id           Int       @id @default(autoincrement())
  userId       Int
  videoId      Int
  watchedSecs  Int       @default(0)
  completed    Boolean   @default(false)
  lastWatched  DateTime  @default(now())

  user         user      @relation(fields: [userId], references: [id])
  video        video     @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
  @@index([videoId])
}

//
// ------------------ WISHLIST ------------------
//

model wishlist {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now())

  userId     Int
  user       user      @relation(fields: [userId], references: [id])

  playlistId Int
  playlist   playlist  @relation(fields: [playlistId], references: [id])

  @@unique([userId, playlistId])
  @@index([userId])
}

//
// ------------------ REVIEW ------------------
//

model review {
  id         Int       @id @default(autoincrement())
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  userId     Int
  user       user      @relation(fields: [userId], references: [id])

  playlistId Int
  playlist   playlist  @relation(fields: [playlistId], references: [id])

  @@unique([userId, playlistId])
  @@index([userId])
}